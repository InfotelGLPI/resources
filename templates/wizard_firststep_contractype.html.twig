{% import 'components/form/basic_inputs_macros.html.twig' as inputs %}
{% import 'components/form/fields_macros.html.twig' as fields %}

{% set rand = random() %}
{% set field_options = {
    'field_class': 'col-4',
} %}
{% if can_edit %}
    <form method="post" action="{{ params["target"] }}" {{ formoptions ?? '' }} enctype="multipart/form-data" data-submit-once>
        <div class="card">
{#            <div class="card-header">#}
                <h3 class="alert alert-secondary" role="alert" style="margin-top: 10px;">
                    <span class="resources_wizard_resp_img">
                        <i class=" {{ params["icon"] }} "></i>&nbsp;
                        <img src=" {{ params["img"] }} ">&nbsp;
                        {{ params["title"] }}
                    </span>
                </h3>
{#            </div>#}
            <div class="card-body">
                <div class='card-text'>
                    {{ __('This wizard lets you create new resources in GLPI', 'resources') }}
                    <br/><br/>
                    {{ __('To begin, select type of contract', 'resources') }}
                    <br/><br/>
                    <div class="row">
                        <div class="form-field row align-items-center col-12 col-sm-6 mb-2">
                            <div class="col-xxl-6 field-container">
                                {{ call('GlpiPlugin\\Resources\\Resource::dropdownTemplate', ["template"]) }}
                            </div>
                        </div>
                    </div>
                    <div class="hr mt-3 mb-3"></div>
                    <div class="hstack gap-1">
                        <div class="pe-5 ms-auto">
                            {{ inputs.hidden('_glpi_csrf_token', csrf_token()) }}
                            {{ inputs.hidden('withtemplate', 2) }}
                            {{ inputs.submit('second_step',
                                _x('button', 'Next', 'resources'),
                                1,
                                {class: 'btn btn-success ms-1',
                                    icon: 'ti ti-chevron-right'}) }}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
{% endif %}

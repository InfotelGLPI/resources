{% import 'components/form/basic_inputs_macros.html.twig' as inputs %}
{% import 'components/form/fields_macros.html.twig' as fields %}

{% set rand = random() %}
{% set field_options = {
    'field_class': 'col-4',
} %}
{% if can_edit %}
    <form method="post" action="{{ params["target"] }}" {{ formoptions ?? '' }} enctype="multipart/form-data"
          data-submit-once>
        <div class="card">
            {#            <div class="card-header"> #}
            <h3 class="card-title alert alert-secondary" style="margin-top: 10px;">
                    <span class="resources_wizard_resp_img">
                        <i class=" {{ params["icon"] }} "></i>&nbsp;
                        <img src=" {{ params["img"] }} ">&nbsp;
                        {{ params["title"] }}
                    </span>
            </h3>
            {#            </div> #}

            <div class="card-body">
                <div class='card-text'>

                    {% for habilitation_level in habilitation_levels %}

                        <div class="form-field row align-items-center col-12 col-sm-6 mb-2">
                            <label class="col-form-label col-xxl-5 text-xxl-end ">
                                {{ habilitation_level.name }}
                                {% if habilitation_level.mandatory %}
                                    <span class="text-danger">*</span>
                                {% endif %}
                            </label>
                            <div class="col-xxl-7 field-container">

                                    {% do call('Dropdown::showFromArray', [
                                        'habilitation_' ~ habilitation_level.id,
                                        habilitation_level.values,
                                        {
                                            'label'    : habilitation_level.name,
                                            'multiple' : habilitation_level.number,
                                            'values'    : existing_habilitations[habilitation_level.id]|default([]),
                                            'required' : habilitation_level.mandatory,
                                        }
                                    ]) %}
                            </div>
                        </div>
                    {% else %}
                        <div class="alert alert-warning">
                            {{ __('No habilitation level, you cannot add habilitation for this resource.', 'resources') }}
                        </div>
                    {% endfor %}

                    {% if params["default_button"] is defined and params["default_button"] ==1 %}
                        {{ include('components/form/buttons.html.twig') }}
                    {% else %}
                        <div class="hr mt-3 mb-3"></div>
                        <div class="hstack gap-1">
                            <div class="pe-5 ms-auto">
                                {{ inputs.hidden('plugin_resources_resources_id', params["plugin_resources_resources_id"]) }}
                                {{ inputs.hidden('id', params["id"]) }}
                                {{ inputs.hidden('withtemplate', 0) }}
                                {{ inputs.hidden('_glpi_csrf_token', csrf_token()) }}

                                {% if can_purge %}
                                    {{ inputs.submit('cancel_request',
                                        _x('button', 'Cancel the request', 'resources'),
                                        1,
                                        {class: 'btn btn-danger ms-1',
                                            icon: 'ti ti-x'}) }}
                                {% endif %}
                                {{ inputs.submit('undo_six_step',
                                    _x('button', 'Previous', 'resources'),
                                    1,
                                    {class: 'btn btn-primary ms-1',
                                        icon: 'ti ti-chevron-left'}) }}

                                {{ inputs.submit('seven_step',
                                    _x('button', 'Next', 'resources'),
                                    1,
                                    {class: 'btn btn-success ms-1',
                                        icon: 'ti ti-chevron-right'}) }}
                            </div>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </form>
{% endif %}
